[user]
	name = Tiago Rodrigues
	email = tmcrodrigues@gmail.com
[alias]
    ci = commit
    sw = switch
    st = status
    br = branch
    mg = merge
    spush = svn dcommit
    spull = svn rebase
    lg = log --color
    di = diff --color
    dito = difftool
    standup = "!git log --since yesterday --author `git config user.email` --pretty=short"
    show-files = show --name-status
  last-hash = log -n 1 --format=%h
[core]
	excludesfile = /Users/trodrigues/.gitignore_global
[difftool]
	prompt = false
[color]
	ui = true
[branch]
  autosetuprebase = always
[push]
	default = simple
[rerere]
	enabled = true
